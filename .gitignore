# Monorepo-wide ignores. The CRA app keeps its own client/.gitignore;
# this file covers the server and repo root.

# Dependencies (any package: client, server, root)
node_modules/

# Server build output
server/dist/

# Environment secrets — never commit. Templates (*.env.example) are tracked.
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor cruft
.DS_Store
