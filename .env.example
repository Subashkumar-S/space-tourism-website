# ─────────────────────────────────────────────────────────────────────────────
# Space Tourism — ONE env file for the whole project (server, client, Compose).
#   cp .env.example .env   # then fill in the secrets below
#
# Keys are prefixed SPACE_ so this project never clashes with the sibling projects
# on the shared host. The app code reads the plain names (SECRET, MONGODB_URI, …):
#   • natively, server/src/config/env.ts aliases SPACE_FOO -> FOO at boot;
#   • in Docker, the server gets this file via env_file and the same aliasing runs
#     in-container; deploy/docker-compose.yml overrides the host-specific values.
# Exception: REACT_APP_API_BASE_URL keeps its framework prefix — CRA only exposes
# vars literally starting with REACT_APP_, so it is NOT renamed to SPACE_.
#
# Run Compose so it reads THIS file:
#   docker compose --env-file .env -f deploy/docker-compose.yml up --build
# ─────────────────────────────────────────────────────────────────────────────

# ── Required secret ──────────────────────────────────────────────────────────
SPACE_SECRET=replace-with-a-long-random-string

# ── Runtime / host binding & ports (Compose) ─────────────────────────────────
SPACE_NODE_ENV=production
SPACE_PORT=5000
SPACE_BIND_IP=127.0.0.1
SPACE_CLIENT_HOST_PORT=8082
SPACE_SERVER_HOST_PORT=8092
SPACE_MONGO_HOST_PORT=27017
SPACE_REDIS_HOST_PORT=6379

# ── Public origin / API base ─────────────────────────────────────────────────
SPACE_CLIENT_ORIGIN=http://localhost:8082
# Same-origin in Docker: the browser calls /api and nginx proxies to the server.
# Keeps the REACT_APP_ prefix (CRA requirement); feeds the Compose client build.
REACT_APP_API_BASE_URL=/api

# ── Data stores (optional) ───────────────────────────────────────────────────
# Leave BLANK to use the bundled mongo/redis containers (Docker) or localhost
# (native dev). Set to managed URLs to override both.
SPACE_MONGODB_URI=
SPACE_REDIS_URL=

# ── Stripe (test mode) ───────────────────────────────────────────────────────
SPACE_STRIPE_SECRET_KEY=
SPACE_STRIPE_WEBHOOK_SECRET=

# ── Booking seat-hold window (minutes; Stripe Checkout needs >= 30) ──────────
SPACE_BOOKING_HOLD_MINUTES=30

# ── Google OAuth (optional — blank disables the Google button) ───────────────
SPACE_GOOGLE_CLIENT_ID=
SPACE_GOOGLE_CLIENT_SECRET=
SPACE_GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── Email via Resend (optional) ──────────────────────────────────────────────
SPACE_RESEND_API_KEY=
SPACE_EMAIL_FROM=Space Tourism <onboarding@resend.dev>

# ── Admin bootstrap (comma-separated emails auto-promoted to admin) ──────────
SPACE_ADMIN_EMAILS=
