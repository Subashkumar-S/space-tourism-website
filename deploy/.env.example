# Docker deployment env for the SPACE-TOURISM stack — read by Compose.
#
#   cp deploy/.env.example deploy/.env
#   docker compose --env-file deploy/.env -f deploy/docker-compose.yml up --build
#
# These are COMPOSE-level variables, prefixed with SPACE_ so they never clash with
# the other projects on a shared host/shell. Compose maps each into the container
# under its normal, unprefixed name, so application code is unchanged.
#
# Container-internal secrets (SECRET, Stripe, Google, Resend, …) live in
# ../server/.env (loaded via env_file) — that file is per-project, so those names
# are already isolated and are NOT prefixed (the app reads them directly).

# ── Host binding & ports (defaults shown) ────────────────────────────
# SPACE_BIND_IP=127.0.0.1
# SPACE_CLIENT_HOST_PORT=8082
# SPACE_SERVER_HOST_PORT=8092
# SPACE_PORT=5000                  # server's in-container port
# SPACE_MONGO_HOST_PORT=27017      # dev stack only
# SPACE_REDIS_HOST_PORT=6379       # dev stack only

# ── Runtime ──────────────────────────────────────────────────────────
# SPACE_NODE_ENV=production
# On the box behind Caddy: SPACE_CLIENT_ORIGIN=https://space.subashkumar.dev
# SPACE_CLIENT_ORIGIN=http://localhost:8082
# SPACE_API_BASE_URL=/api          # client build arg (same-origin via nginx)

# ── Data stores — unset uses the bundled mongo/redis containers ───────
# Set to cloud for production:
# SPACE_MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/space-tourism
# SPACE_REDIS_URL=rediss://default:password@host:6379
