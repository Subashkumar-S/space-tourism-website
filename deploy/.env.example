# Docker deployment env for the SPACE-TOURISM stack — read by Compose.
#   cp deploy/.env.example deploy/.env
#   docker compose --env-file deploy/.env -f deploy/docker-compose.yml up --build
#
# Compose-level vars, prefixed SPACE_ so they never clash with other projects on
# a shared host/shell; each is mapped into the container under its normal name.
# Container-internal secrets (SECRET, Stripe, Google, Resend) live in
# ../server/.env (env_file) and are NOT prefixed. Values below are the local /
# Docker defaults — change per environment.

# Host binding & ports
SPACE_BIND_IP=127.0.0.1
SPACE_CLIENT_HOST_PORT=8082
SPACE_SERVER_HOST_PORT=8092
SPACE_PORT=5000
SPACE_MONGO_HOST_PORT=27017
SPACE_REDIS_HOST_PORT=6379

# Runtime
SPACE_NODE_ENV=production
SPACE_CLIENT_ORIGIN=http://localhost:8082
SPACE_API_BASE_URL=/api

# Data stores — point at the bundled mongo/redis containers; change to cloud URLs
# for a managed datastore.
SPACE_MONGODB_URI=mongodb://mongo:27017/space-tourism
SPACE_REDIS_URL=redis://redis:6379
